# Neon DB — https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require
NUXT_DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Clerk — https://dashboard.clerk.com → API Keys
NUXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NUXT_CLERK_SECRET_KEY=sk_test_...

# Public base URL of the app — used to build absolute redirect URLs for Stripe Checkout and Customer Portal.
# Example: https://yourapp.netlify.app for production; http://localhost:3000 for local dev.
NUXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — https://dashboard.stripe.com → Developers → API Keys
# Secret key (server-only). Used by the billing API to create Checkout and Customer Portal sessions.
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret — https://dashboard.stripe.com → Developers → Webhooks → your endpoint → Signing secret
# Used to verify both inbound source webhooks (Stripe provider) and the billing lifecycle webhook.
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price IDs — https://dashboard.stripe.com → Products → your Pro plan → Pricing
# STRIPE_PRO_PRICE_ID: monthly Pro plan price ID (required for Checkout with priceKey=pro)
# STRIPE_PRO_ANNUAL_PRICE_ID: annual Pro plan price ID (required for Checkout with priceKey=pro_annual)
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...

# Sentry — https://sentry.io → Settings → Projects → Client Keys (DSN)
NUXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=danholloran
SENTRY_PROJECT=markpost
