exports[`sources page > matches snapshot in empty state 1`] = `
"<div active="sources" crumb="WORKSPACE / DAN'S VAULT" title="Sources"><button variant="accent" size="sm" icon="plus">add source</button>
  <div style="padding: 22px 26px 40px; max-width: 920px;">
    <div style="margin-bottom: 18px;">
      <div class="app-alert"> There are only two ways in — a <strong>webhook endpoint</strong> and an <strong>email-in address</strong>. Presets like Stripe or GitHub are just a webhook with provider field-mapping baked in. </div>
