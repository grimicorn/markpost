// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`activity page > matches snapshot in empty state 1`] = `
"<div active="activity" crumb="WORKSPACE / DAN'S VAULT" title="Activity"><button class="app-btn">export log</button>
  <div style="padding: 22px 26px 40px; max-width: 920px;">
    <!-- loading state -->
    <!-- empty state -->
    <div class="col" style="align-items: center; padding: 60px 0px; color: var(--ink-3); gap: 12px; text-align: center;"><span name="fileText" size="32"></span><span style="font-size: 15px; font-weight: 500; color: var(--ink-2);">No activity yet</span><span class="mono" style="font-size: 13px;"> Events will appear here once sources start delivering records. </span></div>
  </div>
</div>"
`;

exports[`activity page > matches snapshot in error state 1`] = `
"<div active="activity" crumb="WORKSPACE / DAN'S VAULT" title="Activity"><button class="app-btn">export log</button>
  <div style="padding: 22px 26px 40px; max-width: 920px;">
    <!-- loading state -->
    <!-- error state -->
    <div class="app-alert" data-tone="err">Failed to load activity. Please try again.</div>
  </div>
</div>"
`;

exports[`activity page > matches snapshot in loading state 1`] = `
"<div active="activity" crumb="WORKSPACE / DAN'S VAULT" title="Activity"><button class="app-btn">export log</button>
  <div style="padding: 22px 26px 40px; max-width: 920px;">
    <!-- loading state -->
    <div class="col" style="align-items: center; padding: 60px 0px; color: var(--ink-3); gap: 12px;"><span name="refresh" size="24"></span><span class="mono" style="font-size: 13px;">loading activity…</span></div>
  </div>
</div>"
`;

exports[`activity page > matches snapshot with events 1`] = `
"<div active="activity" crumb="WORKSPACE / DAN'S VAULT" title="Activity"><button class="app-btn">export log</button>
  <div style="padding: 22px 26px 40px; max-width: 920px;">
    <!-- loading state -->
    <!-- log terminal -->
    <div class="term">
      <div class="term-bar"><span class="dots"><i></i><i></i><i></i></span><span class="t-title">markpost sync --watch</span><span class="grow"></span><span class="t-title" style="margin-left: auto;">live</span></div>
      <div class="term-body" style="max-height: 420px; overflow-y: auto;">
        <div style="display: flex; gap: 12px;"><span class="c-dim" style="flex-grow: 0; flex-shrink: 0; flex-basis: auto;">09:41:02</span><span class="c-ok">✓ webhook github:push → 99-incoming/deploy.md</span></div>
        <div style="display: flex; gap: 12px;"><span class="c-dim" style="flex-grow: 0; flex-shrink: 0; flex-basis: auto;">09:41:02</span><span class="" style="color: var(--err);">✗ conflict: file exists, skipped</span></div>
        <div style="display: flex; gap: 12px; margin-top: 6px;"><span class="pr">$</span><span style="border-left-width: var(--accent); border-left-style: var(--accent); border-left-color: var(--accent);">&nbsp;</span></div>
      </div>
    </div>
  </div>
</div>"
`;
