  </div>
</div>"
`;

exports[`inbox page > matches snapshot with records 1`] = `
"<div active="inbox" crumb="WORKSPACE / DAN'S VAULT" title="Inbox"><button class="app-btn">sync now</button>
  <div style="padding: 22px 26px 40px; max-width: 1080px;">
    <!--v-if-->
    <!--v-if-->
    <!-- stat row -->
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 22px;">
      <div class="card" style="padding: 16px;">
        <div class="row between"><span class="kicker">synced today</span><span name="checkCircle" size="15" style="color: var(--ok);"></span></div>
        <div class="row" style="align-items: baseline; gap: 4px; margin-top: 10px;"><span style="font-size: 28px; font-weight: 600; letter-spacing: -0.02em;" class="tnum">12</span>
          <!--v-if-->
        </div>
      </div>
      <div class="card" style="padding: 16px;">
        <div class="row between"><span class="kicker">pending</span><span name="clock" size="15" style="color: var(--warn);"></span></div>
        <div class="row" style="align-items: baseline; gap: 4px; margin-top: 10px;"><span style="font-size: 28px; font-weight: 600; letter-spacing: -0.02em;" class="tnum">1</span>
          <!--v-if-->
        </div>
      </div>
      <div class="card" style="padding: 16px;">
        <div class="row between"><span class="kicker">errors</span><span name="triangle" size="15" style="color: var(--err);"></span></div>
        <div class="row" style="align-items: baseline; gap: 4px; margin-top: 10px;"><span style="font-size: 28px; font-weight: 600; letter-spacing: -0.02em;" class="tnum">1</span>
          <!--v-if-->
        </div>
      </div>
      <div class="card" style="padding: 16px;">
        <div class="row between"><span class="kicker">this month</span><span name="fileText" size="15" style="color: var(--ink-3);"></span></div>
        <div class="row" style="align-items: baseline; gap: 4px; margin-top: 10px;"><span style="font-size: 28px; font-weight: 600; letter-spacing: -0.02em;" class="tnum">284</span><span class="mono faint" style="font-size: 12px;">/ ∞</span></div>
      </div>
    </div><!-- filters -->
    <div class="row between wrap gap-3" style="margin-bottom: 14px;">
      <div></div><span class="mono faint" style="font-size: 12px;">2 records</span>
    </div><!-- loading state -->
    <!-- table -->
    <!-- empty state -->
    <div class="card" style="overflow: hidden;">
      <div class="row" style="padding: 10px 18px; background: var(--bg-2); font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-3); border-bottom-width: var(--line); border-bottom-style: var(--line); border-bottom-color: var(--line);"><span style="width: 120px;">source</span><span style="flex-grow: 1; flex-shrink: 1; flex-basis: 0%;">record</span><span style="width: 230px;">file</span><span style="width: 90px;">status</span><span style="width: 80px; text-align: right;">time</span></div>
      <div class="divide-y">
        <div class="row" style="padding: 13px 18px; cursor: pointer; transition: background 0.1s;"><span class="row gap-2" style="width: 120px;"><span name="zap" size="15" style="color: var(--accent); flex-grow: 0; flex-shrink: 0; flex-basis: auto;"></span><span class="mono" style="font-size: 11.5px; color: var(--ink-2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">github</span></span><span style="font-size: 14px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; padding-right: 16px; flex-grow: 1; flex-shrink: 1; flex-basis: 0%;">Test Record</span><span class="mono" style="width: 230px; font-size: 11.5px; color: var(--info); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">99-incoming/test.md</span><span style="width: 90px;"><span class="app-badge">synced</span></span><span class="mono faint" style="width: 80px; text-align: right; font-size: 11.5px;">2m ago</span></div>
        <div class="row" style="padding: 13px 18px; cursor: pointer; transition: background 0.1s;"><span class="row gap-2" style="width: 120px;"><span name="zap" size="15" style="color: var(--accent); flex-grow: 0; flex-shrink: 0; flex-basis: auto;"></span><span class="mono" style="font-size: 11.5px; color: var(--ink-2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">github</span></span><span style="font-size: 14px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; padding-right: 16px; flex-grow: 1; flex-shrink: 1; flex-basis: 0%;">Another</span><span class="mono" style="width: 230px; font-size: 11.5px; color: var(--info); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">99-incoming/test.md</span><span style="width: 90px;"><span class="app-badge">synced</span></span><span class="mono faint" style="width: 80px; text-align: right; font-size: 11.5px;">2m ago</span></div>
