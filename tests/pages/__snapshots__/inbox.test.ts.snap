          <!--v-if-->
        </div>
      </div>
      <div class="card" style="padding: 16px;">
        <div class="row between"><span class="kicker">pending</span><span name="clock" size="15" style="color: var(--warn);"></span></div>
        <div class="row" style="align-items: baseline; gap: 4px; margin-top: 10px;"><span style="font-size: 28px; font-weight: 600; letter-spacing: -0.02em;" class="tnum">1</span>
          <!--v-if-->
        </div>
      </div>
      <div class="card" style="padding: 16px;">
        <div class="row between"><span class="kicker">errors</span><span name="triangle" size="15" style="color: var(--err);"></span></div>
        <div class="row" style="align-items: baseline; gap: 4px; margin-top: 10px;"><span style="font-size: 28px; font-weight: 600; letter-spacing: -0.02em;" class="tnum">1</span>
          <!--v-if-->
        </div>
      </div>
      <div class="card" style="padding: 16px;">
        <div class="row between"><span class="kicker">this month</span><span name="fileText" size="15" style="color: var(--ink-3);"></span></div>
        <div class="row" style="align-items: baseline; gap: 4px; margin-top: 10px;"><span style="font-size: 28px; font-weight: 600; letter-spacing: -0.02em;" class="tnum">284</span><span class="mono faint" style="font-size: 12px;">/ ∞</span></div>
      </div>
    </div><!-- filters -->
    <div class="row between wrap gap-3" style="margin-bottom: 14px;">
      <div></div><span class="mono faint" style="font-size: 12px;">0 records</span>
    </div><!-- loading state -->
    <!-- load error state -->
    <div class="app-alert" data-tone="err">Failed to load records. Please try again.</div>
  </div>
</div>"
`;

