// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`InputToggle > matches snapshot 1`] = `"<div class="row gap-3" style="align-items: center;"><label class="switch"><input type="checkbox"><span class="track"></span><span class="thumb"></span></label><span style="font-size: 14px;">Auto-sync</span></div>"`;
