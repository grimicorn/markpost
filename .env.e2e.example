# Neon branch for e2e tests
E2E_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Clerk credentials are read from .env (NUXT_PUBLIC_CLERK_PUBLISHABLE_KEY and
# NUXT_CLERK_SECRET_KEY). The e2e suite provisions its own test user via the
# Clerk Backend API automatically, so no separate test account is needed.
